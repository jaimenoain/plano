{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "topFilesLength": 5,
    "showLineNumbers": true,
    "compress": true,
    "removeComments": true,
    "removeEmptyLines": true
  },
  "input": {
    "maxFileSize": 500000
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "docs/**/*.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "node_modules/**",
      ".next/**",
      ".expo/**",
      "dist/**",
      "build/**",
      "*.lock",
      "*.log",
      "coverage/**",
      ".turbo/**",
      "**/__tests__/**",
      "**/__mocks__/**",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "**/fixtures/**",
      "repomix-output.*"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
