            const { data: commentsData, error: commentsError } = await supabase
                .from("comments")
                .select(`
                    id, content, created_at, user_id,
                    user:profiles(username, avatar_url)
                `)
                .eq("interaction_id", reviewData.id)
                .order("created_at", { ascending: true });
