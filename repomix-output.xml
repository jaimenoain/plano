            >
              {deleting ? "Deleting..." : "Delete Collection"}
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
      {showAddToFolder && currentUserId && (
          <AddToFolderDialog
            open={showAddToFolder}
            onOpenChange={setShowAddToFolder}
            collectionId={collection.id}
            userId={currentUserId}
            onSuccess={fetchCollectionFolders}
          />
      )}
    </Sheet>
  );
}
