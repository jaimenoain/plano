        status: 'ignored', // Should go to bottom
        architects: [],
        image_url: null,
        slug: 'hidden-1',
        lat: 0,
        lng: 0,
      },
      {
        id: '2',
        name: 'Visible Building 1',
        rating: 3,
        status: 'saved', // Should stay at top
        architects: [],
        image_url: null,
        slug: 'visible-1',
        lat: 0,
        lng: 0,
      },
      {
        id: '3',
        name: 'Hidden Building 2',
        rating: 3,
        status: 'ignored', // Should go to bottom
        architects: [],
        image_url: null,
        slug: 'hidden-2',
        lat: 0,
        lng: 0,
      },
      {
        id: '4',
        name: 'Visible Building 2',
        rating: 3,
        status: 'visited', // Should stay at top
        architects: [],
        image_url: null,
        slug: 'visible-2',
        lat: 0,
