);

CREATE TYPE public.credit_tier_enum AS ENUM ('primary', 'contributor', 'ancillary');

CREATE TABLE public.people (
  id uuid NOT NULL,
  name text NOT NULL,
  slug text NOT NULL UNIQUE,
  bio text,
  nationality text,
  birth_year integer,
  death_year integer,
  avatar_url text,
