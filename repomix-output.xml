      description: `You're now on v${version}. Reload for the latest experience.`,
      action: {
        label: "Reload",
        onClick: () => window.location.reload(),
      },
      duration: 15_000,
    });
  }, []);
  useVersionNotification(notifyVersion);
  useLoginTracker();
  usePresenceTracker();
  useEffect(() => {
    if (authLoading) return;
    setSentryUser(user?.id ?? null);
  }, [user, authLoading]);
