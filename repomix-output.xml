                    </AccordionContent>
                </AccordionItem>
                {/* Item 3: Materiality */}
                <AccordionItem value="materiality">
                    <AccordionTrigger className="text-sm">Materiality</AccordionTrigger>
                    <AccordionContent className="pt-2">
