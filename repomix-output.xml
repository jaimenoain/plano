  },
  building: {
    id: 'b-1',
    name: 'Test Building',
    address: '123 Test St',
    year_completed: '2020',
    main_image_url: null,
    slug: 'test-building',
    short_id: 'tb1',
    creditedEntities: [],
  },
  tags: [],
  likes_count: 5,
  comments_count: 2,
  is_liked: false,
  watch_with_users: [],
  images: [],
};
