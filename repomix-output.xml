        </Tabs>
        <div className="mt-auto pt-4 border-t">
          <SheetFooter>
            {canEdit ? (
              <Button onClick={handleSaveGeneral} disabled={saving} className="w-full">
                {saving && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
                Save Changes
