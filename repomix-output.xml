        <div className="flex-1 flex justify-start pl-2 overflow-hidden">
          {instructions ? (
            <span className="text-xs text-text-secondary truncate" title={instructions}>
              {instructions}
            </span>
          ) : null}
        </div>
      </div>
    </div>
  );
}
interface ItineraryDayColumnProps {
