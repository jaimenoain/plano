                              Visited
                            </Badge>
                          )}
                        </div>
                        <div className="text-xs text-text-secondary flex items-center gap-1">
                          {formatDate(review.created_at)}
                        </div>
                      </div>
                    </div>
                    {/* Rating */}
                    {!isBucketList && review.rating && (
                      <div className="flex gap-0.5">
                        {Array.from({ length: 3 }).map((_, i) => (
                          <Circle
