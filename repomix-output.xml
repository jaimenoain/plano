CREATE POLICY "user_buildings_select" ON user_buildings
  FOR SELECT USING (
    user_id = (SELECT auth.uid())
    OR visibility = 'public'
    OR (
      visibility = 'contacts'
      AND EXISTS (
        SELECT 1 FROM follows
        WHERE follower_id = (SELECT auth.uid())
        AND following_id = user_buildings.user_id
      )
    )
  );
```

