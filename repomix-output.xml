                        />
                    </AccordionContent>
                </AccordionItem>
                {/* Credits: company + role on building_credits (map/list RPCs) */}
                <AccordionItem value="credits">
                    <AccordionTrigger className="text-sm">Credits</AccordionTrigger>
                    <AccordionContent className="space-y-4 pt-2">
