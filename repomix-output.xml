          <p className="text-sm text-text-secondary leading-relaxed">
            Keep track of every architectural masterpiece you've visited.
          </p>
        </div>
        <div className="space-y-2">
          {["Unité d'Habitation", "Barbican Centre", "Villa Savoye"].map(
            (name) => (
              <div
