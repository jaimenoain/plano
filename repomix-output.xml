  user_id     uuid NOT NULL,
  status      text NOT NULL DEFAULT 'pending'
              CHECK (status IN ('pending', 'processing', 'completed', 'failed')),
  bucket_name text NOT NULL DEFAULT 'review_images',
  logs        jsonb DEFAULT '[]',
