    <SidebarProvider
      defaultOpen={true}
      initialOpen={initialSidebarOpen ?? undefined}
    >
      <TooltipProvider>
        <PwaProvider>
          <GoogleAnalytics />
          <Analytics />
          <CookieConsent />
          <PwaPrompt />
          <Toaster />
          <Sonner />
          <Outlet />
        </PwaProvider>
      </TooltipProvider>
