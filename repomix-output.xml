  USING (
    owner_id = (SELECT auth.uid())
    OR EXISTS (
      SELECT 1 FROM collection_contributors cc
      WHERE cc.collection_id = id
      AND cc.user_id = (SELECT auth.uid())
      AND cc.role IN ('admin', 'editor')
