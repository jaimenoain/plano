                        transition={{ duration: 0.25 }}
                      >
                        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 pb-20">
                          {filteredContent.map((item) => (
                            <ReviewCard
                              key={item.id}
                              entry={item}
                              onLike={handleLike}
                              hideUser
                              variant="compact"
                              showCommunityImages={showCommunityImages}
                            />
                          ))}
                        </div>
                      </motion.div>
                    ) : viewMode === 'list' ? (
                      <motion.div
                        key="list"
                        variants={variants}
                        initial="initial"
                        animate="animate"
                        exit="exit"
                        transition={{ duration: 0.25 }}
                      >
                        <ProfileListView
                            data={filteredContent}
                            isOwnProfile={isOwnProfile}
                            onUpdate={handleUpdate}
                        />
                      </motion.div>
                    ) : (
                      <motion.div
                        key="kanban"
                        variants={variants}
                        initial="initial"
                        animate="animate"
                        exit="exit"
                        transition={{ duration: 0.25 }}
                      >
