# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# Storage (optional override — defaults to https://s3.eu-west-2.amazonaws.com/plano.app)
VITE_PUBLIC_STORAGE_URL=

# Monitoring (optional)
VITE_SENTRY_DSN=
VITE_GA_MEASUREMENT_ID=

# Sitemap proxy — generate with: openssl rand -hex 32
# Must match the SITEMAP_INTERNAL_TOKEN Supabase secret.
# Set in Vercel project env vars (all environments).
SITEMAP_INTERNAL_TOKEN=

# Feedback system
# Supabase service role key — used server-side only for screenshot uploads to private bucket.
SUPABASE_SERVICE_ROLE_KEY=
# Webhook URL — POST fired on every new feedback submission. Optional; omit to disable.
FEEDBACK_WEBHOOK_URL=

# AI event discovery (admin)
# Anthropic API key — used server-side for AI-powered architecture event search.
ANTHROPIC_API_KEY=
# Serper.dev API key — used server-side by the embassy event-search pipeline
# (src/features/embassy/api/event-search.route.ts). Required for /embassy event discovery.
SERPER_API_KEY=

# Superadmin access
# Comma-separated, case-insensitive list of emails granted the superadmin UI
# (src/features/superadmin/lib/superadminAccess.ts). Leave empty to disable.
VITE_SUPERADMIN_EMAILS=

# E2E tests (Playwright, tests/e2e/)
# Dedicated QA account (role='test_user') — never a real user's credentials.
# In CI these come from GitHub Actions secrets of the same name.
ACTIVE_USER_EMAIL=
ACTIVE_USER_PASSWORD=

# Naming note: some ad-hoc verifier scripts in scripts/ read non-VITE aliases
# (SUPABASE_URL, SUPABASE_ANON_KEY, GOOGLE_MAPS_API_KEY). The app itself only
# needs the VITE_-prefixed values above; export the aliases manually if you run
# those scripts.

