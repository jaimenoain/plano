# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# Storage (optional override — defaults to https://s3.eu-west-2.amazonaws.com/plano.app)
VITE_PUBLIC_STORAGE_URL=

# Monitoring (optional)
VITE_SENTRY_DSN=
VITE_GA_MEASUREMENT_ID=

# Sitemap proxy — generate with: openssl rand -hex 32
# Must match the SITEMAP_INTERNAL_TOKEN Supabase secret.
# Set in Vercel project env vars (all environments).
SITEMAP_INTERNAL_TOKEN=

# Feedback system
# Supabase service role key — used server-side only for screenshot uploads to private bucket.
SUPABASE_SERVICE_ROLE_KEY=
# Webhook URL — POST fired on every new feedback submission. Optional; omit to disable.
FEEDBACK_WEBHOOK_URL=

