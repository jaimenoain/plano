{
  "pkg": "plano",
  "globalName": "Plano",
  "shape": "package",
  "srcDir": "src/components/ui",
  "tsconfig": "tsconfig.json",
  "cssEntry": ".design-sync/ds-styles.css",
  "buildCmd": ".ds-sync/node_modules/.bin/tailwindcss -i .design-sync/ds-entry.v4.css -o .design-sync/ds-styles.css --minify",
  "readmeHeader": ".design-sync/conventions.md",
  "guidelinesGlob": ["design-system/README.md"],
  "docsDir": ".design-sync/docs",
  "extraFonts": [".design-sync/fonts/fonts.css"],
  "runtimeFontPrefixes": ["Cambria"],
  "overrides": {
    "Dialog": { "cardMode": "single", "viewport": "720x540" },
    "AlertDialog": { "cardMode": "single", "viewport": "720x520" },
    "Sheet": { "cardMode": "single", "viewport": "900x560" },
    "Drawer": { "cardMode": "single", "viewport": "640x600" },
    "Popover": { "cardMode": "single", "viewport": "520x440" },
    "HoverCard": { "cardMode": "single", "viewport": "520x420" },
    "Tooltip": { "cardMode": "single", "viewport": "440x320" },
    "DropdownMenu": { "cardMode": "single", "viewport": "480x480" },
    "ContextMenu": { "cardMode": "single", "viewport": "520x480" },
    "Menubar": { "cardMode": "single", "viewport": "660x440" },
    "Select": { "cardMode": "single", "viewport": "480x500" },
    "NavigationMenu": { "cardMode": "single", "viewport": "760x440" },
    "Command": { "cardMode": "single", "viewport": "580x500" },
    "Sidebar": { "cardMode": "single", "viewport": "960x600" },
    "ChartContainer": { "cardMode": "single", "viewport": "720x460" },
    "Carousel": { "cardMode": "single", "viewport": "640x480" },
    "Command": { "cardMode": "single", "viewport": "560x520" },
    "Toaster": { "cardMode": "single", "viewport": "480x360" },
    "Table": { "cardMode": "column" },
    "Form": { "cardMode": "column" },
    "TagInput": { "cardMode": "column" },
    "AspectRatio": { "cardMode": "column" },
    "ResizablePanelGroup": { "cardMode": "column" },
    "Pagination": { "cardMode": "column" },
    "Tabs": { "cardMode": "column" }
  },
  "componentSrcMap": {
    "Accordion": "src/components/ui/accordion.tsx",
    "AlertDialog": "src/components/ui/alert-dialog.tsx",
    "Alert": "src/components/ui/alert.tsx",
    "AspectRatio": "src/components/ui/aspect-ratio.tsx",
    "Avatar": "src/components/ui/avatar.tsx",
    "Badge": "src/components/ui/badge.tsx",
    "Breadcrumb": "src/components/ui/breadcrumb.tsx",
    "Button": "src/components/ui/button.tsx",
    "Calendar": "src/components/ui/calendar.tsx",
    "Card": "src/components/ui/card.tsx",
    "Carousel": "src/components/ui/carousel.tsx",
    "ChartContainer": "src/components/ui/chart.tsx",
    "Checkbox": "src/components/ui/checkbox.tsx",
    "Collapsible": "src/components/ui/collapsible.tsx",
    "Command": "src/components/ui/command.tsx",
    "ContextMenu": "src/components/ui/context-menu.tsx",
    "Dialog": "src/components/ui/dialog.tsx",
    "Drawer": "src/components/ui/drawer.tsx",
    "DropdownMenu": "src/components/ui/dropdown-menu.tsx",
    "Form": "src/components/ui/form.tsx",
    "HoverCard": "src/components/ui/hover-card.tsx",
    "InputOTP": "src/components/ui/input-otp.tsx",
    "Input": "src/components/ui/input.tsx",
    "Label": "src/components/ui/label.tsx",
    "Menubar": "src/components/ui/menubar.tsx",
    "MichelinRatingInput": "src/components/ui/michelin-rating-input.tsx",
    "NavigationMenu": "src/components/ui/navigation-menu.tsx",
    "Pagination": "src/components/ui/pagination.tsx",
    "Popover": "src/components/ui/popover.tsx",
    "Progress": "src/components/ui/progress.tsx",
    "RadioGroup": "src/components/ui/radio-group.tsx",
    "ResizablePanelGroup": "src/components/ui/resizable.tsx",
    "ScrollArea": "src/components/ui/scroll-area.tsx",
    "SegmentedControl": "src/components/ui/segmented-control.tsx",
    "Select": "src/components/ui/select.tsx",
    "Separator": "src/components/ui/separator.tsx",
    "Sheet": "src/components/ui/sheet.tsx",
    "Sidebar": "src/components/ui/sidebar.tsx",
    "Skeleton": "src/components/ui/skeleton.tsx",
    "Slider": "src/components/ui/slider.tsx",
    "Toaster": "src/components/ui/sonner.tsx",
    "Switch": "src/components/ui/switch.tsx",
    "Table": "src/components/ui/table.tsx",
    "Tabs": "src/components/ui/tabs.tsx",
    "TagInput": "src/components/ui/tag-input.tsx",
    "Textarea": "src/components/ui/textarea.tsx",
    "ToggleGroup": "src/components/ui/toggle-group.tsx",
    "Toggle": "src/components/ui/toggle.tsx",
    "Tooltip": "src/components/ui/tooltip.tsx",
    "VideoPlayer": "src/components/ui/VideoPlayer.tsx"
  }
}
